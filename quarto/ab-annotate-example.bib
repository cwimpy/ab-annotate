% ab-annotate-example.bib
% Sample entries demonstrating all four cases:
%   1. Both abstract and annotation
%   2. Abstract only
%   3. Annotation only
%   4. Neither (plain citation)

@article{kimball2013,
  author    = {Kimball, David C. and Kropf, Martha},
  title     = {Election Administration Costs and Voter Turnout},
  journal   = {State and Local Government Review},
  year      = {2013},
  volume    = {45},
  number    = {3},
  pages     = {173--183},
  abstract  = {This study examines how election administration spending
               relates to voter turnout across U.S. counties. Using data
               from the 2008 presidential election, the authors find that
               higher per-voter spending is associated with modest
               increases in turnout, particularly in jurisdictions with
               lower population density.},
  annotation = {Foundational for the cost-capacity link in rural
                jurisdictions. Their per-voter spending measure is worth
                adapting for the EAVS-based rurality framework---could
                combine with RUCC codes to test whether the spending-turnout
                relationship is moderated by rurality. Table 2 has the
                key regression results.}
}

@book{hale2015,
  author    = {Hale, Kathleen and Montjoy, Robert and Brown, Mitchell},
  title     = {Administering Elections: How American Elections Work},
  publisher = {Palgrave Macmillan},
  year      = {2015},
  address   = {New York},
  abstract  = {A comprehensive overview of election administration in the
               United States, covering the decentralized structure of
               electoral governance, the role of local election officials,
               and the policy challenges of running elections across
               diverse jurisdictional contexts.}
}

@article{mcneal2023,
  author    = {McNeal, Ramona and Schmeida, Mary},
  title     = {Digital Divides and Democratic Participation in Rural
               Communities},
  journal   = {Social Science Quarterly},
  year      = {2023},
  volume    = {104},
  number    = {5},
  pages     = {890--912},
  annotation = {Useful for framing the broadband-democracy connection
                but doesn't engage with election administration directly.
                The rural typology they use (metro/nonmetro binary) is
                too coarse---good example of why a continuous rurality
                measure matters. Cite in the lit review but push back
                on the measurement approach.}
}

